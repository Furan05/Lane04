# Relais Garmin LANE 04 — copier en .env (jamais commité) puis exporter,
# ou fournir ces variables par l'environnement du service (systemd, fly.io…).

# Identifiants du Garmin Connect Developer Program (portail développeur).
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# URL publique du relais (https en production) — base du redirect_uri
# à déclarer chez Garmin : <PUBLIC_BASE_URL>/v1/garmin/oauth/callback
PUBLIC_BASE_URL=https://relay.example.com
PORT=8080

# Optionnel :
# DATA_DIR=./data
# APP_CALLBACK_URL=lane04://garmin/oauth/callback
# GARMIN_AUTHORIZE_URL=https://connect.garmin.com/oauth2Confirm
# GARMIN_TOKEN_URL=https://diauth.garmin.com/di-oauth2-service/oauth/token
# GARMIN_API_BASE=https://apis.garmin.com
# GARMIN_WORKOUT_PATH=/training-api/workout
# GARMIN_SCHEDULE_PATH=/training-api/schedule
# GARMIN_USER_ID_PATH=/wellness-api/rest/user/id
# GARMIN_DEREGISTRATION_PATH=/wellness-api/rest/user/registration
